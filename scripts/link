#! /bin/sh

set -e

cd -- "${0%/*}"/..

set -xe

PREFIX="$1"
shift

test "$#" = 0

mkdir -p -- "$PREFIX"/bin
mkdir -p -- "$PREFIX"/share/volodyslav

if command -v rsync >/dev/null 2>&1
then
    COPY="rsync --recursive --partial --delete --links"
else
    COPY="cp -r -T"
    rm -rf -- "$PREFIX"/share/volodyslav/source
fi

$COPY -- "$PWD"/ "$PREFIX"/share/volodyslav/source/

# Capture the version from the source repository and store it for the installed version
if command -v git >/dev/null 2>&1
then
    VERSION=$(git describe 2>/dev/null || echo "unknown")
else
    echo "This program requires git to capture the version, but git is not installed." >&2
    exit 1
fi
echo "$VERSION" > "$PREFIX"/share/volodyslav/source/VERSION

# Capture the base path from VOLODYSLAV_BASEURL and store it for the installed version
BASE_URL="${VOLODYSLAV_BASEURL:-}"
if [ -n "$BASE_URL" ]
then
    BASE_PATH=$(node -e "
        const u = process.env['VOLODYSLAV_BASEURL'] || '';
        try {
            const url = new URL(u);
            process.stdout.write(url.pathname.replace(/\/+\$/, ''));
        } catch (_) {
            let p = u;
            if (!p.startsWith('/')) { p = '/' + p; }
            process.stdout.write(p.replace(/\/+\$/, ''));
        }
    ")
else
    BASE_PATH=""
fi
printf '%s' "$BASE_PATH" > "$PREFIX"/share/volodyslav/source/BASE_PATH

# Remove .git to avoid broken references in submodule setups
rm -rf -- "$PREFIX"/share/volodyslav/source/.git

ln -srfT -- "$PREFIX"/share/volodyslav/source/scripts/run-main "$PREFIX"/bin/volodyslav
