{
  "name": "volodyslav",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "frontend",
    "backend",
    "docs"
  ],
  "scripts": {
    "dev": "sh scripts/run-development-server",
    "build": "npm run build -w frontend",
    "start": "npm run build && npm run start -w backend",
    "static-analysis": "tsc && eslint . --max-warnings 0",
    "test": "jest",
    "test-only": "jest",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix --max-warnings 0",
    "docs:dev": "npm run dev -w docs",
    "docs:build": "npm run build -w docs",
    "rules:test": "npm --prefix tools/eslint-plugin-volodyslav run test",
    "rules:new": "node scripts/new-rule.mjs",
    "backend:migration-fixture:update": "node scripts/update-migration-fixture-populated-remote.js"
  },
  "devDependencies": {
    "@babel/core": "^8.0.1",
    "@babel/preset-env": "^8.0.1",
    "@babel/preset-react": "^8.0.1",
    "@eslint-react/eslint-plugin": "^5.10.3",
    "@eslint/js": "^10.0.1",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/luxon": "^3.7.2",
    "@types/node": "^25.6.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/supertest": "^2.0.12",
    "@typescript-eslint/eslint-plugin": "^8.62.1",
    "@typescript-eslint/parser": "^8.62.1",
    "babel-jest": "^30.4.1",
    "concurrently": "^10.0.3",
    "eslint": "^10.6.0",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-import-x": "^4.14.22",
    "eslint-plugin-jest": "^29.15.4",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-volodyslav": "file:tools/eslint-plugin-volodyslav",
    "globals": "^16.5.0",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "jiti": "^2.6.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.62.1"
  }
}
