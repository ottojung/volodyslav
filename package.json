{
  "name": "volodyslav",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "frontend",
    "backend",
    "docs"
  ],
  "scripts": {
    "dev": "sh scripts/run-development-server",
    "build": "npm run build -w frontend",
    "start": "npm run build && npm run start -w backend",
    "static-analysis": "tsc && eslint . --max-warnings 0 --report-unused-disable-directives",
    "test": "jest",
    "test-only": "jest",
    "lint": "eslint . --ext .js,.jsx --max-warnings 0 --report-unused-disable-directives",
    "lint:fix": "eslint . --ext .js,.jsx --fix --max-warnings 0 --report-unused-disable-directives",
    "docs:dev": "npm run dev -w docs",
    "docs:build": "npm run build -w docs",
    "rules:test": "npm --prefix tools/eslint-plugin-volodyslav run test",
    "rules:new": "node scripts/new-rule.mjs",
    "backend:migration-fixture:update": "node scripts/update-migration-fixture-populated-remote.js"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.2",
    "@babel/preset-react": "^7.28.5",
    "@types/express": "^4.17.17",
    "@types/jest": "^30.0.0",
    "@types/luxon": "^3.7.1",
    "@types/node": "^25.6.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/supertest": "^2.0.12",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.32.1",
    "babel-jest": "^30.4.1",
    "concurrently": "^9.2.1",
    "eslint": "^8.57.1",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-jest": "^29.15.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-volodyslav": "file:tools/eslint-plugin-volodyslav",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.4.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "typescript": "^5.9.3"
  }
}
